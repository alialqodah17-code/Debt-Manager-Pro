{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; if [ -n \"$CI\" ] || [ -n \"$EAS_BUILD\" ]; then exit 0; fi; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm -r --if-present --no-bail run build",
    "typecheck:libs": "echo skipping...",
    "typecheck": "pnpm -r --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "@types/react": "18.2.0",
    "@types/react-dom": "18.2.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "dependencies": {
    "lucide-react": "^1.11.0",
    "react": "18.2.0",
    "react-dom": "18.2.0"
  }
}
